rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function authSignInProvider() {
      return (
        request.auth.token.keys().hasAny(['firebase'])
        && request.auth.token.firebase is map
        && request.auth.token.firebase.keys().hasAny(['sign_in_provider'])
        && request.auth.token.firebase.sign_in_provider is string
      )
        ? request.auth.token.firebase.sign_in_provider
        : '';
    }

    function isNonAnonymousAuthed() {
      return isAuthed() && authSignInProvider() != 'anonymous';
    }

    function isSuperAdmin() {
      return isAuthed()
        && (
          (
            request.auth.token.keys().hasAny(['super_admin'])
            && request.auth.token.super_admin == true
          )
          || (
            request.auth.token.keys().hasAny(['superAdmin'])
            && request.auth.token.superAdmin == true
          )
          || (
            request.auth.token.keys().hasAny(['email'])
            && request.auth.token.keys().hasAny(['email_verified'])
            && request.auth.token.email is string
            && request.auth.token.email == 'hello@beauross.com'
            && request.auth.token.email_verified == true
          )
        );
    }

    function isBrossApp(appId) {
      return appId == 'bross-app';
    }

    function roomDocPath(roomCode) {
      return /databases/$(database)/documents/artifacts/bross-app/public/data/rooms/$(roomCode);
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function roomExists(roomCode) {
      return roomCode is string && exists(roomDocPath(roomCode));
    }

    function isRoomHost(roomCode) {
      return isAuthed()
        && roomExists(roomCode)
        && (
          isSuperAdmin()
          || (
            get(roomDocPath(roomCode)).data.hostUid == request.auth.uid
            || (
              get(roomDocPath(roomCode)).data.hostUids is list
              && request.auth.uid in get(roomDocPath(roomCode)).data.hostUids
            )
          )
        );
    }

    function isValidRoomUserId(roomUserId, roomCode, uid) {
      return roomCode is string
        && uid is string
        && roomUserId == roomCode + "_" + uid;
    }

    function asNumberOrZero(v) {
      return v is number ? v : 0;
    }

    function roomUserPhoneNotIntroducedOrModified(prevData, nextData) {
      return !nextData.diff(prevData).affectedKeys().hasAny(['phone'])
        || !nextData.keys().hasAny(['phone']);
    }

    function roomUserCreateAllowedKeys() {
      return [
        'uid',
        'roomCode',
        'name',
        'avatar',
        'isVip',
        'vipLevel',
        'fameLevel',
        'totalFamePoints',
        'lastActiveAt',
        'points',
        'totalEmojis',
        'lastSeen',
        'visits',
        'isReady',
        'tight15Temp'
      ];
    }

    function roomUserSelfWritableKeys() {
      return [
        'name',
        'avatar',
        'isVip',
        'vipLevel',
        'fameLevel',
        'totalFamePoints',
        'lastActiveAt',
        'lastSeen',
        'points',
        'totalEmojis',
        'lastPerformanceId',
        'performancePointsGifted',
        'totalPointsGifted',
        'guitarSessionId',
        'guitarHits',
        'strobeSessionId',
        'strobeTaps',
        'stormLayerHits',
        'lastStormLayer',
        'lastVibeAt',
        'tight15Temp',
        'isReady',
        'visits',
        'bingoVotesBySession'
      ];
    }

    function roomUserSelfChangedKeysAllowed(prevData, nextData) {
      return nextData.diff(prevData).affectedKeys().hasOnly(roomUserSelfWritableKeys());
    }

    function roomUserPointsDeltaWithinLimit(prevData, nextData) {
      return !nextData.diff(prevData).affectedKeys().hasAny(['points'])
        || (
          nextData.points is number
          && nextData.points <= asNumberOrZero(prevData.points) + 10000
          && nextData.points >= asNumberOrZero(prevData.points) - 10000
        );
    }

    function canonicalVipLevel(uid) {
      return uid is string
        && exists(userDocPath(uid))
        && get(userDocPath(uid)).data.vipLevel is number
        ? get(userDocPath(uid)).data.vipLevel
        : 0;
    }

    function canonicalFameLevel(uid) {
      return uid is string
        && exists(userDocPath(uid))
        && (
          get(userDocPath(uid)).data.currentLevel is number
          || get(userDocPath(uid)).data.fameLevel is number
        )
        ? (
          get(userDocPath(uid)).data.currentLevel is number
            ? get(userDocPath(uid)).data.currentLevel
            : get(userDocPath(uid)).data.fameLevel
        )
        : 0;
    }

    function canonicalTotalFamePoints(uid) {
      return uid is string
        && exists(userDocPath(uid))
        && get(userDocPath(uid)).data.totalFamePoints is number
        ? get(userDocPath(uid)).data.totalFamePoints
        : 0;
    }

    function roomUserPrivilegeProjectionWithinAccount(uid, nextData) {
      return (
        !nextData.keys().hasAny(['vipLevel'])
        || (
          nextData.vipLevel is number
          && nextData.vipLevel >= 0
          && nextData.vipLevel <= canonicalVipLevel(uid)
        )
      )
        && (
          !nextData.keys().hasAny(['isVip'])
          || (
            nextData.isVip is bool
            && (
              nextData.isVip == false
              || canonicalVipLevel(uid) > 0
            )
          )
        )
        && (
          !nextData.keys().hasAny(['fameLevel'])
          || (
            nextData.fameLevel is number
            && nextData.fameLevel >= 0
            && nextData.fameLevel <= canonicalFameLevel(uid)
          )
        )
        && (
          !nextData.keys().hasAny(['totalFamePoints'])
          || (
            nextData.totalFamePoints is number
            && nextData.totalFamePoints >= 0
            && nextData.totalFamePoints <= canonicalTotalFamePoints(uid)
          )
        );
    }

    function activityAllowedKeys() {
      return [
        'roomCode',
        'uid',
        'user',
        'text',
        'icon',
        'timestamp'
      ];
    }

    function reactionAllowedKeys() {
      return [
        'roomCode',
        'type',
        'count',
        'uid',
        'userName',
        'avatar',
        'isVip',
        'multiplier',
        'performanceId',
        'performanceSongId',
        'performanceSingerUid',
        'performanceSingerName',
        'performanceStartedAtMs',
        'timestamp',
        'layer',
        'url',
        'storagePath',
        'mode',
        'val',
        'questionId',
        'songId',
        'sessionId',
        'team',
        'isFree',
        'isVote'
      ];
    }

    function guestVoteReactionAllowedTypes() {
      return [
        'vote_wyr',
        'vote_trivia',
        'vote_popup_trivia'
      ];
    }

    function guestVoteReactionAllowedKeys() {
      return [
        'roomCode',
        'type',
        'userName',
        'avatar',
        'uid',
        'timestamp',
        'val',
        'questionId',
        'songId',
        'isVote',
        'performanceId',
        'performanceSongId',
        'performanceSingerUid',
        'performanceSingerName',
        'performanceStartedAtMs'
      ];
    }

    function isGuestVoteReactionCreate(data) {
      return data.type is string
        && data.type in guestVoteReactionAllowedTypes()
        && data.keys().hasOnly(guestVoteReactionAllowedKeys())
        && data.keys().hasAny(['isVote'])
        && data.isVote == true
        && (
          !data.keys().hasAny(['uid'])
          || data.uid == null
        );
    }

    function hasSafeClientSubscriptionDefaults(data) {
      return !data.keys().hasAny(['subscription'])
        || (
          data.subscription is map
          && (
            !data.subscription.keys().hasAny(['tier'])
            || (data.subscription.tier is string && data.subscription.tier == 'free')
          )
          && (
            !data.subscription.keys().hasAny(['plan'])
            || (data.subscription.plan is string && data.subscription.plan in ['monthly', 'yearly'])
          )
          && (
            !data.subscription.keys().hasAny(['startDate'])
            || data.subscription.startDate == null
          )
          && (
            !data.subscription.keys().hasAny(['renewalDate'])
            || data.subscription.renewalDate == null
          )
          && (
            !data.subscription.keys().hasAny(['cancelledAt'])
            || data.subscription.cancelledAt == null
          )
          && (
            !data.subscription.keys().hasAny(['paymentMethod'])
            || data.subscription.paymentMethod == null
          )
        );
    }

    function hasSafeClientOrganizationDefaults(data) {
      return !data.keys().hasAny(['organization'])
        || (
          data.organization is map
          && (
            !data.organization.keys().hasAny(['orgId'])
            || data.organization.orgId == null
          )
          && (
            !data.organization.keys().hasAny(['role'])
            || (data.organization.role is string && data.organization.role == 'member')
          )
          && (
            !data.organization.keys().hasAny(['updatedAt'])
            || data.organization.updatedAt == null
          )
        );
    }

    function userPrivilegeManagedKeys() {
      return [
        'vipLevel',
        'isVip',
        'fameLevel',
        'totalFamePoints',
        'currentLevel',
        'levelProgress',
        'unlockedBadges',
        'unlockedAvatars',
        'lastPerformanceScore',
        'phone'
      ];
    }

    function userPrivilegeFieldsUnchanged(prevData, nextData) {
      return (
        !nextData.keys().hasAny(['vipLevel'])
        || (prevData.keys().hasAny(['vipLevel']) && nextData.vipLevel == prevData.vipLevel)
      )
        && (
          !nextData.keys().hasAny(['isVip'])
          || (prevData.keys().hasAny(['isVip']) && nextData.isVip == prevData.isVip)
        )
        && (
          !nextData.keys().hasAny(['fameLevel'])
          || (prevData.keys().hasAny(['fameLevel']) && nextData.fameLevel == prevData.fameLevel)
        )
        && (
          !nextData.keys().hasAny(['totalFamePoints'])
          || (prevData.keys().hasAny(['totalFamePoints']) && nextData.totalFamePoints == prevData.totalFamePoints)
        )
        && (
          !nextData.keys().hasAny(['currentLevel'])
          || (prevData.keys().hasAny(['currentLevel']) && nextData.currentLevel == prevData.currentLevel)
        )
        && (
          !nextData.keys().hasAny(['levelProgress'])
          || (prevData.keys().hasAny(['levelProgress']) && nextData.levelProgress == prevData.levelProgress)
        )
        && (
          !nextData.keys().hasAny(['unlockedBadges'])
          || (prevData.keys().hasAny(['unlockedBadges']) && nextData.unlockedBadges == prevData.unlockedBadges)
        )
        && (
          !nextData.keys().hasAny(['unlockedAvatars'])
          || (prevData.keys().hasAny(['unlockedAvatars']) && nextData.unlockedAvatars == prevData.unlockedAvatars)
        )
        && (
          !nextData.keys().hasAny(['lastPerformanceScore'])
          || (prevData.keys().hasAny(['lastPerformanceScore']) && nextData.lastPerformanceScore == prevData.lastPerformanceScore)
        )
        && (
          !nextData.keys().hasAny(['phone'])
          || (prevData.keys().hasAny(['phone']) && nextData.phone == prevData.phone)
        );
    }

    function directoryRoleDocPath(uid) {
      return /databases/$(database)/documents/directory_roles/$(uid);
    }

    function marketingPrivateAccessDocPath(uid) {
      return /databases/$(database)/documents/marketing_private_access/$(uid);
    }

    function hasMarketingPrivateHostAccess(uid) {
      return uid is string
        && exists(marketingPrivateAccessDocPath(uid))
        && get(marketingPrivateAccessDocPath(uid)).data.privateHostAccessEnabled == true;
    }

    function requestsPrivateHostRole(data) {
      return data.roles is list
        && (
          "host" in data.roles
          || "venue_owner" in data.roles
        );
    }

    function isDirectoryModerator() {
      return isAuthed()
        && (
          isSuperAdmin()
          || (
            exists(directoryRoleDocPath(request.auth.uid))
            && (
              (
                get(directoryRoleDocPath(request.auth.uid)).data.roles is list
                && "directory_editor" in get(directoryRoleDocPath(request.auth.uid)).data.roles
              )
              || (
                get(directoryRoleDocPath(request.auth.uid)).data.roles is list
                && "directory_admin" in get(directoryRoleDocPath(request.auth.uid)).data.roles
              )
            )
          )
        );
    }

    function isPublicApproved(data) {
      return data.status == "approved"
        && (
          !(data.visibility is string)
          || data.visibility == "public"
        );
    }

    function nonHostRoomWritableKeys() {
      return [
        'activeMode',
        'activeScreen',
        'applausePeak',
        'bingoMysteryRng',
        'currentApplauseLevel',
        'doodleOke',
        'gameData',
        'guitarVictory',
        'guitarWinner',
        'lightMode',
        'photoOverlay',
        'strobeResults',
        'strobeVictory',
        'strobeWinner'
      ];
    }

    // User profiles
    match /users/{uid} {
      allow read: if isAuthed()
        && (
          request.auth.uid == uid
          || isDirectoryModerator()
        );
      allow create: if isAuthed()
        && request.auth.uid == uid
        && (
          !request.resource.data.keys().hasAny(['uid'])
          || (
            request.resource.data.uid is string
            && request.resource.data.uid == uid
          )
        )
        && !request.resource.data.keys().hasAny(userPrivilegeManagedKeys())
        && hasSafeClientSubscriptionDefaults(request.resource.data)
        && hasSafeClientOrganizationDefaults(request.resource.data);
      allow update: if isAuthed()
        && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).changedKeys().hasAny(['subscription', 'organization'])
        && !request.resource.data.diff(resource.data).changedKeys().hasAny(userPrivilegeManagedKeys())
        && userPrivilegeFieldsUnchanged(resource.data, request.resource.data);
      allow delete: if false;
    }

    match /private_user_settings/{uid} {
      allow read, create, update, delete: if isAuthed() && request.auth.uid == uid;
    }

    match /directory_profiles/{uid} {
      allow read: if isPublicApproved(resource.data)
        || (isAuthed() && request.auth.uid == uid)
        || isDirectoryModerator();
      allow create, update: if isAuthed()
        && request.auth.uid == uid
        && (
          !requestsPrivateHostRole(request.resource.data)
          || hasMarketingPrivateHostAccess(uid)
          || isDirectoryModerator()
        );
      allow delete: if false;
    }

    match /directory_roles/{uid} {
      allow read: if isAuthed() && (request.auth.uid == uid || isDirectoryModerator());
      allow write: if false;
    }

    match /marketing_private_access/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow write: if false;
    }

    match /venues/{venueId} {
      allow read: if isPublicApproved(resource.data)
        || isDirectoryModerator()
        || (isAuthed() && resource.data.ownerUid == request.auth.uid);
      allow write: if false;
    }

    match /karaoke_events/{eventId} {
      allow read: if isPublicApproved(resource.data)
        || isDirectoryModerator()
        || (isAuthed() && resource.data.ownerUid == request.auth.uid);
      allow write: if false;
    }

    match /room_sessions/{sessionId} {
      allow read: if (
        resource.data.status == "approved"
        && resource.data.visibility == "public"
      )
        || isDirectoryModerator()
        || (isAuthed() && resource.data.ownerUid == request.auth.uid);
      allow write: if false;
    }

    match /directory_submissions/{submissionId} {
      allow read: if isAuthed()
        && (
          resource.data.createdBy == request.auth.uid
          || isDirectoryModerator()
        );
      allow write: if false;
    }

    match /directory_claim_requests/{claimId} {
      allow read: if isAuthed()
        && (
          resource.data.createdBy == request.auth.uid
          || isDirectoryModerator()
        );
      allow create: if isAuthed()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.listingType is string
        && request.resource.data.listingId is string;
      allow update, delete: if false;
    }

    match /directory_rsvps/{docId} {
      allow read: if isAuthed()
        && (
          resource.data.uid == request.auth.uid
          || isDirectoryModerator()
        );
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.targetType is string
        && request.resource.data.targetId is string;
      allow update, delete: if isAuthed()
        && (
          resource.data.uid == request.auth.uid
          || isDirectoryModerator()
        );
    }

    match /directory_reminders/{docId} {
      allow read: if isAuthed()
        && (
          resource.data.uid == request.auth.uid
          || isDirectoryModerator()
        );
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.targetType is string
        && request.resource.data.targetId is string;
      allow update, delete: if isAuthed()
        && (
          resource.data.uid == request.auth.uid
          || isDirectoryModerator()
        );
    }

    match /directory_geo_pages/{token} {
      allow read: if true;
      allow write: if false;
    }

    match /directory_reminder_dispatch/{docId} {
      allow read: if isDirectoryModerator();
      allow write: if false;
    }

    match /directory_reminder_jobs/{docId} {
      allow read: if isDirectoryModerator();
      allow write: if false;
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuthed()
        && request.resource.data.followerUid == request.auth.uid
        && request.resource.data.targetType is string
        && request.resource.data.targetId is string;
      allow update: if false;
      allow delete: if isAuthed()
        && (
          resource.data.followerUid == request.auth.uid
          || isDirectoryModerator()
        );
    }

    match /checkins/{checkinId} {
      allow read: if resource.data.isPublic == true
        || (
          isAuthed()
          && (
            resource.data.uid == request.auth.uid
            || isDirectoryModerator()
          )
        );
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.targetType is string
        && request.resource.data.targetId is string;
      allow update, delete: if isAuthed()
        && (
          resource.data.uid == request.auth.uid
          || isDirectoryModerator()
        );
    }

    match /checkin_totals/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.targetType is string
        && request.resource.data.targetId is string
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if isAuthed()
        && (
          resource.data.uid == request.auth.uid
          || isDirectoryModerator()
        );
    }

    match /review_totals/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /external_source_links/{docId} {
      allow read: if isDirectoryModerator();
      allow write: if false;
    }

    match /directory_sync_jobs/{docId} {
      allow read: if isDirectoryModerator();
      allow write: if false;
    }

    match /directory_regions/{regionId} {
      allow read: if true;
      allow write: if false;
    }

    // Global catalog + leaderboards (read-only to clients; writes via Admin SDK)
    match /songs/{songId} {
      allow read: if true;
      allow write: if false;
    }

    match /tracks/{trackId} {
      allow read: if true;
      allow write: if false;
    }

    match /song_lyrics/{songId} {
      allow read: if true;
      allow write: if false;
    }

    match /performances/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /song_hall_of_fame/{songId} {
      allow read: if true;
      allow write: if false;
    }

    match /song_hall_of_fame_weeks/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /feedback/{docId} {
      allow read: if false;
      allow create: if isAuthed();
      allow update, delete: if false;
    }

    // App data used by TV/Singer/Host
    match /artifacts/{appId}/public/data {
      allow read: if isBrossApp(appId);

      match /rooms/{roomCode} {
        allow create: if isBrossApp(appId)
          && isAuthed()
          && request.resource.data.hostUid == request.auth.uid
          && request.resource.data.hostUids is list
          && request.auth.uid in request.resource.data.hostUids;

        // Direct client writes are limited to non-host participants and only
        // for explicitly whitelisted room fields. Host mutations are callable-only.
        allow update: if isBrossApp(appId)
          && isAuthed()
          && !isRoomHost(roomCode)
          && request.resource.data.hostUid == resource.data.hostUid
          && request.resource.data.hostUids == resource.data.hostUids
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(nonHostRoomWritableKeys());

        allow delete: if isBrossApp(appId) && isRoomHost(roomCode);
      }

      match /host_libraries/{roomCode} {
        allow create, update, delete: if isBrossApp(appId) && isRoomHost(roomCode);
      }

      match /room_uploads/{uploadId} {
        allow read: if isBrossApp(appId) && isAuthed() && isRoomHost(resource.data.roomCode);
        allow create: if isBrossApp(appId)
          && isAuthed()
          && request.resource.data.roomCode is string
          && isRoomHost(request.resource.data.roomCode);
        allow delete: if isBrossApp(appId) && isAuthed() && isRoomHost(resource.data.roomCode);
        allow update: if false;
      }

      match /room_users/{roomUserId} {
        allow create: if isBrossApp(appId)
          && isAuthed()
          && isValidRoomUserId(roomUserId, request.resource.data.roomCode, request.resource.data.uid)
          && request.resource.data.uid == request.auth.uid
          && roomExists(request.resource.data.roomCode)
          && request.resource.data.keys().hasOnly(roomUserCreateAllowedKeys())
          && roomUserPrivilegeProjectionWithinAccount(request.auth.uid, request.resource.data)
          && !request.resource.data.keys().hasAny(['phone']);

        allow update: if isBrossApp(appId)
          && isAuthed()
          && isValidRoomUserId(roomUserId, request.resource.data.roomCode, request.resource.data.uid)
          && request.resource.data.roomCode == resource.data.roomCode
          && request.resource.data.uid == resource.data.uid
          && roomUserPhoneNotIntroducedOrModified(resource.data, request.resource.data)
          && (
            (
              request.auth.uid == resource.data.uid
              && roomUserSelfChangedKeysAllowed(resource.data, request.resource.data)
              && roomUserPointsDeltaWithinLimit(resource.data, request.resource.data)
              && roomUserPrivilegeProjectionWithinAccount(request.auth.uid, request.resource.data)
            )
            || isRoomHost(resource.data.roomCode)
          );

        allow delete: if isBrossApp(appId)
          && isAuthed()
          && (
            request.auth.uid == resource.data.uid
            || isRoomHost(resource.data.roomCode)
          );
      }

      match /karaoke_songs/{songId} {
        allow create: if isBrossApp(appId)
          && isAuthed()
          && request.resource.data.roomCode is string
          && (
            isRoomHost(request.resource.data.roomCode)
            || request.resource.data.singerUid == request.auth.uid
          );

        allow update: if isBrossApp(appId)
          && isAuthed()
          && request.resource.data.roomCode == resource.data.roomCode
          && (
            isRoomHost(resource.data.roomCode)
            || (
              request.resource.data.diff(resource.data).changedKeys().hasOnly(['hypeScore'])
              && request.resource.data.hypeScore is number
              && request.resource.data.hypeScore >= asNumberOrZero(resource.data.hypeScore)
              && request.resource.data.hypeScore <= asNumberOrZero(resource.data.hypeScore) + 500
            )
          );

        allow delete: if isBrossApp(appId)
          && isAuthed()
          && (
            isRoomHost(resource.data.roomCode)
            || (
              resource.data.singerUid is string
              && resource.data.singerUid == request.auth.uid
            )
          );
      }

      match /selfie_submissions/{docId} {
        allow create: if isBrossApp(appId)
          && isAuthed()
          && request.resource.data.roomCode is string
          && request.resource.data.uid == request.auth.uid;
        allow update: if false;
        allow delete: if isBrossApp(appId)
          && isAuthed()
          && (
            isRoomHost(resource.data.roomCode)
            || resource.data.uid == request.auth.uid
          );
      }

      match /selfie_votes/{docId} {
        allow create: if isBrossApp(appId)
          && isAuthed()
          && request.resource.data.roomCode is string
          && request.resource.data.voterUid == request.auth.uid;
        allow update, delete: if false;
      }

      match /doodle_submissions/{docId} {
        allow create: if isBrossApp(appId)
          && isAuthed()
          && request.resource.data.roomCode is string
          && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }

      match /doodle_votes/{docId} {
        allow create: if isBrossApp(appId)
          && isAuthed()
          && request.resource.data.roomCode is string
          && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }

      match /chat_messages/{docId} {
        allow create: if isBrossApp(appId)
          && isNonAnonymousAuthed()
          && request.resource.data.roomCode is string
          && roomExists(request.resource.data.roomCode)
          && request.resource.data.uid is string
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.user is string
          && request.resource.data.user.size() > 0
          && request.resource.data.user.size() <= 80
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 300
          && (
            !request.resource.data.keys().hasAny(['channel'])
            || (
              request.resource.data.channel is string
              && request.resource.data.channel in ['lounge', 'host', 'dm']
            )
          )
          && (
            !request.resource.data.keys().hasAny(['toUid'])
            || (
              request.resource.data.toUid is string
              && request.resource.data.toUid.size() > 0
              && request.resource.data.toUid.size() <= 180
            )
          );
        allow update, delete: if false;
      }

      match /activities/{docId} {
        allow create: if isBrossApp(appId)
          && isAuthed()
          && request.resource.data.roomCode is string
          && roomExists(request.resource.data.roomCode)
          && request.resource.data.keys().hasOnly(activityAllowedKeys())
          && request.resource.data.user is string
          && request.resource.data.user.size() > 0
          && request.resource.data.user.size() <= 80
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 300
          && (
            !request.resource.data.keys().hasAny(['icon'])
            || (
              request.resource.data.icon is string
              && request.resource.data.icon.size() > 0
              && request.resource.data.icon.size() <= 32
            )
          )
          && (
            isRoomHost(request.resource.data.roomCode)
            || (
              request.resource.data.keys().hasAny(['uid'])
              && request.resource.data.uid is string
              && request.resource.data.uid == request.auth.uid
            )
          );
        allow update, delete: if false;
      }

      match /reactions/{docId} {
        allow create: if isBrossApp(appId)
          && (
            isAuthed()
            || isGuestVoteReactionCreate(request.resource.data)
          )
          && request.resource.data.roomCode is string
          && roomExists(request.resource.data.roomCode)
          && request.resource.data.keys().hasOnly(reactionAllowedKeys())
          && request.resource.data.type is string
          && request.resource.data.type.size() > 0
          && request.resource.data.type.size() <= 64
          && request.resource.data.userName is string
          && request.resource.data.userName.size() > 0
          && request.resource.data.userName.size() <= 80
          && (
            !request.resource.data.keys().hasAny(['count'])
            || (
              request.resource.data.count is number
              && request.resource.data.count >= 0
              && request.resource.data.count <= 500
            )
          )
          && (
            !request.resource.data.keys().hasAny(['uid'])
            || (
              request.resource.data.uid == null
              || (
                request.resource.data.uid is string
                && (
                  request.resource.data.uid == request.auth.uid
                  || isRoomHost(request.resource.data.roomCode)
                )
              )
            )
          )
          && (
            !request.resource.data.keys().hasAny(['avatar'])
            || (
              request.resource.data.avatar is string
              && request.resource.data.avatar.size() > 0
              && request.resource.data.avatar.size() <= 64
            )
          )
          && (
            !request.resource.data.keys().hasAny(['layer'])
            || (
              request.resource.data.layer is string
              && request.resource.data.layer.size() > 0
              && request.resource.data.layer.size() <= 64
            )
          )
          && (
            !request.resource.data.keys().hasAny(['url'])
            || (
              request.resource.data.url is string
              && request.resource.data.url.size() > 0
              && request.resource.data.url.size() <= 4096
            )
          )
          && (
            !request.resource.data.keys().hasAny(['storagePath'])
            || (
              request.resource.data.storagePath is string
              && request.resource.data.storagePath.size() > 0
              && request.resource.data.storagePath.size() <= 512
            )
          )
          && (
            !request.resource.data.keys().hasAny(['mode'])
            || (
              request.resource.data.mode is string
              && request.resource.data.mode.size() > 0
              && request.resource.data.mode.size() <= 64
            )
          )
          && (
            !request.resource.data.keys().hasAny(['questionId'])
            || (
              request.resource.data.questionId is string
              && request.resource.data.questionId.size() > 0
              && request.resource.data.questionId.size() <= 180
            )
          )
          && (
            !request.resource.data.keys().hasAny(['sessionId'])
            || (
              request.resource.data.sessionId is string
              && request.resource.data.sessionId.size() > 0
              && request.resource.data.sessionId.size() <= 180
            )
          )
          && (
            !request.resource.data.keys().hasAny(['team'])
            || (
              request.resource.data.team is string
              && request.resource.data.team in ['left', 'right']
            )
          )
          && (
            !request.resource.data.keys().hasAny(['isFree'])
            || request.resource.data.isFree is bool
          )
          && (
            !request.resource.data.keys().hasAny(['isVote'])
            || request.resource.data.isVote is bool
          )
          && (
            !request.resource.data.keys().hasAny(['isVip'])
            || request.resource.data.isVip is bool
          )
          && (
            !request.resource.data.keys().hasAny(['multiplier'])
            || (
              request.resource.data.multiplier is number
              && request.resource.data.multiplier >= 1
              && request.resource.data.multiplier <= 100
            )
          )
          && (
            !request.resource.data.keys().hasAny(['val'])
            || (
              (
                request.resource.data.val is int
                && request.resource.data.val >= -1
                && request.resource.data.val <= 32
              )
              || (
                request.resource.data.val is string
                && request.resource.data.val in ['A', 'B', 'C', 'D']
              )
            )
          );
        allow update: if false;
        allow delete: if false;
      }

      match /contacts/{docId} {
        allow write: if false;
      }

      match /messages/{docId} {
        allow write: if false;
      }

      match /smoke_tests/{docId} {
        allow create: if isBrossApp(appId)
          && isAuthed()
          && request.resource.data.uid == request.auth.uid;
        allow update: if isBrossApp(appId)
          && isAuthed()
          && request.resource.data.uid == request.auth.uid
          && resource.data.uid == request.auth.uid;
        allow read, delete: if isBrossApp(appId)
          && isAuthed()
          && resource.data.uid == request.auth.uid;
      }

      match /{document=**} {
        allow read: if isBrossApp(appId);
        allow write: if false;
      }
    }

    // Everything else locked
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
