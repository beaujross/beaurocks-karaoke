{
  "name": "beaurocks-karaoke",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "seo:sitemap": "node scripts/generate-sitemap.mjs --output-dir public",
    "seo:cards": "node scripts/generate-sitemap.mjs --output-dir dist",
    "seo:build": "node scripts/generate-sitemap.mjs --output-dir public",
    "seo:build:dist": "node scripts/generate-sitemap.mjs --output-dir dist",
    "seo:sitemap:dist": "node scripts/generate-sitemap.mjs --output-dir dist",
    "dev": "vite",
    "build": "vite build && npm run seo:build:dist && node scripts/generate-asset-aliases.mjs",
    "lint": "eslint \"src/**/*.{js,jsx}\" \"functions/**/*.js\" \"scripts/**/*.js\"",
    "lint:emoji": "node scripts/scan-emoji.js",
    "test": "npm run lint && npm run test:unit && npm run test:rules && npm run test:callables",
    "ci:lint": "npm run lint",
    "ci:test:unit": "npm run test:unit",
    "ci:test:unit:coverage": "npm run test:unit:coverage",
    "ci:test:rules": "npm run test:rules",
    "ci:test:callables": "npm run test:callables",
    "ci:build": "npm run build",
    "ci:qa:audience": "npm run qa:audience:app",
    "ci": "npm run ci:lint && npm run ci:test:unit && npm run ci:test:unit:coverage && npm run ci:test:rules && npm run ci:test:callables && npm run ci:build && npm run ci:qa:audience",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:rules": "npx firebase-tools emulators:exec --project demo-bross --only firestore,storage \"node tests/security/rules.test.cjs\"",
    "test:callables": "npm run test:callables:host-access && npm run test:callables:room-provision && npm run test:callables:room && npm run test:callables:webhooks && npm run test:callables:directory && npm run test:callables:marketing-notifications && npm run test:callables:lyrics",
    "test:callables:host-access": "npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/hostAccessGuardrails.test.cjs\"",
    "test:callables:room-provision": "npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/provisionHostRoomCallable.test.cjs\"",
    "test:callables:room": "npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/updateRoomAsHostCallable.test.cjs\" && npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/joinRoomAudienceCallable.test.cjs\" && npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/audienceQueueCallable.test.cjs\" && npx firebase-tools emulators:exec --project demo-bross --only firestore,storage \"node tests/integration/uploadAudienceRoomPhotoCallable.test.cjs\" && npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/selfieChallengeCallable.test.cjs\" && npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/doodleOkeCallable.test.cjs\" && npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/promptVoteCallable.test.cjs\" && npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/bingoCallable.test.cjs\" && npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/karaokeBracketCallable.test.cjs\"",
    "test:callables:webhooks": "npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/givebutterWebhook.test.cjs\"",
    "test:callables:directory": "npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/directoryCallables.test.cjs\"",
    "test:callables:marketing-notifications": "npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/marketingWaitlistNotifications.test.cjs\"",
    "test:callables:lyrics": "npx firebase-tools emulators:exec --project demo-bross --only firestore \"node tests/integration/resolveQueueSongLyricsCallable.test.cjs\"",
    "qa:admin:prod": "node scripts/qa/admin-workspace-playwright-smoke.mjs",
    "qa:personas:prod": "node scripts/qa/persona-golden-paths-playwright.mjs",
    "qa:marketing:golden": "node scripts/qa/marketing-golden-paths-playwright.mjs",
    "qa:marketing:cross-surface": "node scripts/qa/marketing-cross-surface-attribution-playwright.mjs",
    "qa:marketing:host-waitlist": "node scripts/qa/marketing-host-waitlist-playwright.mjs",
    "qa:golden:host-room-hands-off": "node scripts/qa/host-room-hands-off-golden-playwright.mjs",
    "qa:golden:host-room-hands-off:secure": "node scripts/qa/run-host-room-hands-off-secure.mjs",
    "qa:release:core-night": "node scripts/qa/run-host-room-hands-off-secure.mjs",
    "qa:games:matrix": "node scripts/qa/host-game-matrix-playwright.mjs",
    "qa:games:voice-local": "node scripts/qa/voice-games-fun-playwright.mjs",
    "qa:games:matrix:secure": "node scripts/qa/run-host-game-matrix-secure.mjs",
    "qa:host:run-of-show": "node scripts/qa/host-run-of-show-console-playwright.mjs",
    "qa:host:run-of-show:app": "node scripts/qa/host-run-of-show-hostapp-playwright.mjs",
    "qa:audience:app": "node scripts/qa/audience-event-profile-playwright.mjs && node scripts/qa/audience-aahf-branding-visuals.mjs",
    "qa:audience:branding": "node scripts/qa/audience-aahf-branding-visuals.mjs",
    "qa:audience:crowd-selfie": "node scripts/qa/crowd-selfie-flow-playwright.mjs",
    "qa:audience:screenshots": "node scripts/qa/audience-shell-before-after-screenshots.mjs",
    "qa:tv:run-of-show": "node scripts/qa/public-tv-run-of-show-visuals.mjs",
    "test:e2e": "npm run build && npm run qa:marketing:golden && npm run qa:marketing:cross-surface && npm run qa:marketing:host-waitlist && npm run qa:host:run-of-show && npm run qa:host:run-of-show:app && npm run qa:audience:app && npm run qa:games:voice-local && npm run qa:tv:run-of-show",
    "qa:agent:brief": "node scripts/qa/generate-agent-mode-brief.mjs",
    "qa:dual:hands-off": "npm run qa:release:core-night && npm run qa:agent:brief",
    "qa:release:marketing-golden": "node scripts/qa/marketing-golden-paths-playwright.mjs --release-gate",
    "qa:release:marketing-cross-surface": "node scripts/qa/marketing-cross-surface-attribution-playwright.mjs --release-gate",
    "qa:admin:prod:install": "npx playwright install chromium",
    "qa:p0:appcheck": "node scripts/qa/app-check-gate-smoke.mjs",
    "qa:p0:host-join": "node scripts/qa/host-join-playtest.mjs",
    "qa:p0:vip-readiness": "node scripts/qa/vip-sms-readiness.mjs",
    "qa:p0:users": "node scripts/qa/users-profile-smoke.mjs",
    "qa:p0:firebase-safety": "npm run test:rules && npm run qa:p0:appcheck",
    "qa:p0": "npm run qa:p0:firebase-safety && npm run qa:p0:host-join && npm run qa:p0:vip-readiness && npm run qa:p0:users",
    "qa:overnight:smoke": "node scripts/qa/overnight-audience-tv-host-smoke.mjs",
    "ops:alerts:setup": "powershell -ExecutionPolicy Bypass -File scripts/ops/setup-launch-alerts.ps1",
    "ops:alerts:verify": "powershell -ExecutionPolicy Bypass -File scripts/ops/verify-launch-alerts.ps1",
    "ops:watch:launch": "powershell -ExecutionPolicy Bypass -File scripts/ops/watch-launch-signals.ps1",
    "ops:report:playtest": "node scripts/ops/playtest-room-report.mjs",
    "ops:appcheck:event-mode": "node scripts/ops/set-app-check-event-mode.mjs",
    "ops:appcheck:event-mode:check": "node scripts/ops/set-app-check-event-mode.mjs --check",
    "ops:audit:async-pipelines": "node scripts/ops/async-pipeline-audit.mjs",
    "ops:overnight:intelligence": "node scripts/ops/overnight-product-intelligence.mjs",
    "seed:directory:import": "node scripts/ingest/import-kitsap-seed.mjs --help",
    "seed:directory:kitsap:rest": "node scripts/ingest/seed-kitsap-directory-rest.mjs --help",
    "seed:directory:kitsap:geocode": "node scripts/ingest/geocode-kitsap-venues.mjs",
    "seed:directory:venues:photos": "node scripts/ingest/backfill-venue-featured-images.mjs --dry-run",
    "seed:directory:seattle-tacoma:scrape": "node scripts/ingest/scrape-seattle-tacoma-sources.mjs --dry-run",
    "seed:directory:seattle-tacoma:apply": "node scripts/ingest/scrape-seattle-tacoma-sources.mjs --apply",
    "seed:directory:hosts:official": "node scripts/ingest/seed-official-host-profiles.mjs --dry-run",
    "seed:directory:hosts:official:apply": "node scripts/ingest/seed-official-host-profiles.mjs --apply",
    "seed:directory:bootstrap": "node scripts/ingest/bootstrap-directory-profiles.mjs --dry-run",
    "ops:overnight:directory-growth": "node scripts/ops/overnight-directory-growth.mjs",
    "preview": "vite preview",
    "deploy:hosting": "npm run build && npx firebase-tools deploy --only hosting",
    "deploy:hosting:ci": "npx firebase-tools deploy --only hosting --non-interactive"
  },
  "dependencies": {
    "firebase": "^12.7.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.49.1",
    "sharp": "^0.34.4",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "vite": "npm:rolldown-vite@7.2.5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  }
}
